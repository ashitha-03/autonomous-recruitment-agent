# =============================================
#  Autonomous Recruitment Agent - ENV TEMPLATE
#  Copy this to .env and fill in your values
# =============================================

# --- Google Cloud ---
GOOGLE_CLOUD_PROJECT_ID=interns2026
GOOGLE_APPLICATION_CREDENTIALS=config/credentials.json   # Service Account JSON path
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-1.5-pro                           # or gemini-1.0-pro

# --- Google Sheets ---
SPREADSHEET_ID=your-google-sheet-id                     # From the Sheet URL
SHEET_NAME_CANDIDATES=Candidates
SHEET_NAME_JOB_DESCRIPTIONS=JobDescriptions

# --- Gmail OAuth (for sending emails AS a user) ---
GMAIL_OAUTH_CLIENT_ID=your-oauth-client-id
GMAIL_OAUTH_CLIENT_SECRET=your-oauth-client-secret
GMAIL_OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback
GMAIL_SENDER_EMAIL=hr@yourcompany.com

# --- Google Calendar ---
CALENDAR_ID=primary                                      # or specific calendar ID
INTERVIEW_DURATION_MINUTES=45

# --- LinkedIn Scraping (Apify) ---
APIFY_API_TOKEN=your-apify-token                        # https://apify.com

# --- Supabase (replaces Google Sheets as database) ---
